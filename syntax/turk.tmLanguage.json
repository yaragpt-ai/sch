{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "T횥RK",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#literals" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.turk",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.turk",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.turk",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.turk",
                    "match": "\\\\."
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.turk",
                    "match": "\\b(e휓er|de휓ilse|ile|i챌in|yap|d철n|dur|devam|ve|veya|de휓il)\\b"
                },
                {
                    "name": "keyword.control.turk",
                    "match": "\\b(de휓ilse\\s+e휓er)\\b"
                },
                {
                    "name": "keyword.other.turk",
                    "match": "\\b(fonk|yap캇|s캇n캇f|철zel|herkes|yava힊|statik|sabit|deneme|yakala|at)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.turk",
                    "match": "\\b(tamsay캇|ondal캇k|metin|mant캇k|karakter|liste|bo힊)\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.language.turk",
                    "match": "\\b(do휓ru|yanl캇힊|bo힊_de휓er)\\b"
                },
                {
                    "name": "constant.numeric.turk",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.turk",
                    "match": "(==|!=|<=|>=|&&|\\|\\||\\+\\+|--|\\+=|-=|\\*=|/=|\\+|-|\\*|/|%|!|<|>|=)"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.turk",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.turk",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    },
    "scopeName": "source.turk"
}
